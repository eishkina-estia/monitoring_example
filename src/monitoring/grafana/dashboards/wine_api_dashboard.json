{
  "title": "Wine Model Monitoring",
  "uid": "wine-api-monitoring",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Prediction Requests Rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(prediction_requests_total[1m])",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prediction Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(prediction_request_errors_total[1m])",
          "legendFormat": "errors/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prediction Latency (seconds)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(prediction_latency_seconds_sum[1m]) / rate(prediction_latency_seconds_count[1m])",
          "legendFormat": "avg latency",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Model Version",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "model_info",
          "legendFormat": "{{model_name}} v{{model_version}}",
          "refId": "A"
        }
      ]
    }
  ],
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timezone": "browser"
}